<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sazón Costeño – Gestión del Local</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  :root {
    --naranja: #E8651A;
    --naranja-light: #F5913A;
    --amarillo: #F5C518;
    --cafe: #6B3A1F;
    --cafe-light: #9B5E35;
    --crema: #FFF8EE;
    --crema2: #FFF0D6;
    --verde: #2E7D5E;
    --rojo: #C0392B;
    --gris: #888;
    --sombra: 0 4px 20px rgba(107,58,31,0.15);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--crema);
    color: var(--cafe);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: #000;
    color: var(--crema);
    padding: 6px 14px 6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 4px 16px rgba(0,0,0,0.5);
    position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid #1a1a1a;
  }
  header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    line-height: 1.1;
  }
  header h1 span { color: var(--amarillo); display: block; font-size: 0.85rem; font-family: 'Nunito', sans-serif; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; }
  .header-fecha {
    text-align: right;
  }
  .dia-selector {
    background: rgba(255,255,255,0.15);
    border: 1.5px solid rgba(255,255,255,0.3);
    color: white;
    border-radius: 8px;
    padding: 5px 10px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .dia-selector option { color: var(--cafe); background: white; }

  /* TABS */
  .tabs {
    display: flex;
    background: var(--cafe);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs::-webkit-scrollbar { display: none; }
  .tab {
    flex: 1; min-width: 80px;
    padding: 12px 8px;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    transition: all 0.2s;
    border-bottom: 3px solid transparent;
    white-space: nowrap;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .tab:hover { color: white; }
  .tab.active {
    color: var(--amarillo);
    border-bottom-color: var(--amarillo);
  }
  .tab-icon { display: block; font-size: 1.2rem; margin-bottom: 2px; }

  /* CONTENT */
  .content { display: none; padding: 16px; max-width: 700px; margin: 0 auto; }
  .content.active { display: block; }

  /* CARDS */
  .card {
    background: white;
    border-radius: 16px;
    padding: 18px;
    margin-bottom: 16px;
    box-shadow: var(--sombra);
  }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--cafe);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* PRODUCT ROWS */
  .producto-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px dashed var(--crema2);
    gap: 8px;
  }
  .producto-row:last-child { border-bottom: none; }
  .prod-info { flex: 1; }
  .prod-nombre { font-weight: 700; font-size: 0.9rem; }
  .prod-precio { font-size: 0.78rem; color: var(--naranja); font-weight: 600; }
  .prod-subtipo {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }
  .tipo-btn {
    background: var(--crema2);
    border: 1.5px solid var(--crema2);
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--cafe-light);
    cursor: pointer;
    transition: all 0.15s;
  }
  .tipo-btn.selected { background: var(--naranja); border-color: var(--naranja); color: white; }

  .qty-control {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .qty-btn {
    width: 30px; height: 30px;
    border-radius: 50%;
    border: none;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.1s;
  }
  .qty-btn:active { transform: scale(0.9); }
  .qty-minus { background: #f0f0f0; color: var(--cafe); }
  .qty-plus { background: var(--naranja); color: white; }
  .qty-num {
    font-size: 1rem;
    font-weight: 800;
    min-width: 24px;
    text-align: center;
    color: var(--cafe);
  }

  /* PLATO COMPACT CARD */
  .plato-compact {
    background: var(--crema);
    border-radius: 12px;
    padding: 12px 14px;
    margin-bottom: 10px;
  }
  .plato-compact:last-child { margin-bottom: 0; }
  .plato-compact-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .plato-compact-nombre { font-weight: 800; font-size: 0.95rem; color: var(--cafe); }
  .plato-compact-precio { font-size: 1.15rem; font-weight: 900; color: var(--naranja); }
  .plato-compact-opts { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
  .tog-group { display: flex; gap: 4px; background: white; border-radius: 8px; padding: 3px; border: 1.5px solid var(--crema2); }
  .tog-btn {
    border: none; background: transparent; border-radius: 6px;
    padding: 5px 10px; font-family: 'Nunito', sans-serif;
    font-size: 0.78rem; font-weight: 700; color: var(--gris);
    cursor: pointer; transition: all 0.15s; white-space: nowrap;
  }
  .tog-btn.tog-active { background: var(--naranja); color: white; }
  .plato-compact-bottom { display: flex; align-items: center; justify-content: space-between; }
  .plato-compact-sel {
    font-size: 0.78rem; font-weight: 700; color: var(--cafe-light);
    background: white; padding: 4px 10px; border-radius: 20px; border: 1.5px solid var(--crema2);
  }

  /* COLA SELECTOR */
  .cola-marca {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .marca-btn {
    background: var(--crema2);
    border: 1.5px solid transparent;
    border-radius: 20px;
    padding: 2px 8px;
    font-size: 0.68rem;
    font-weight: 700;
    cursor: pointer;
    color: var(--cafe);
    transition: all 0.15s;
  }
  .marca-btn.selected { background: var(--cafe); color: white; }

  /* RESUMEN FLOTANTE */
  .resumen-flotante {
    position: fixed;
    bottom: 16px; right: 16px;
    background: var(--naranja);
    color: white;
    border-radius: 50px;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 6px 24px rgba(232,101,26,0.4);
    cursor: pointer;
    z-index: 200;
    font-weight: 800;
    font-size: 1rem;
    transition: transform 0.2s;
  }
  .resumen-flotante:hover { transform: scale(1.05); }

  /* BOTONES */
  .btn {
    padding: 10px 20px;
    border-radius: 10px;
    border: none;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 0.9rem;
  }
  .btn:active { transform: scale(0.97); }
  .btn-primary { background: var(--naranja); color: white; }
  .btn-primary:hover { background: var(--naranja-light); }
  .btn-success { background: var(--verde); color: white; }
  .btn-danger { background: var(--rojo); color: white; }
  .btn-outline { background: transparent; border: 2px solid var(--naranja); color: var(--naranja); }
  .btn-sm { padding: 6px 12px; font-size: 0.8rem; }
  .btn-full { width: 100%; margin-top: 12px; padding: 14px; font-size: 1rem; }

  /* INPUTS */
  .form-group { margin-bottom: 12px; }
  .form-group label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--cafe-light); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .form-control {
    width: 100%;
    padding: 10px 14px;
    border: 2px solid var(--crema2);
    border-radius: 10px;
    font-family: 'Nunito', sans-serif;
    font-size: 0.95rem;
    color: var(--cafe);
    background: var(--crema);
    transition: border-color 0.2s;
  }
  .form-control:focus { outline: none; border-color: var(--naranja); }

  /* LISTAS DE GASTOS/COMPRAS/DEUDAS */
  .item-lista {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: var(--crema);
    border-radius: 10px;
    margin-bottom: 8px;
    gap: 8px;
  }
  .item-lista-nombre { font-weight: 700; font-size: 0.9rem; flex: 1; }
  .item-lista-monto { font-weight: 800; color: var(--naranja); font-size: 0.95rem; }
  .item-lista-nota { font-size: 0.75rem; color: var(--gris); }
  .btn-eliminar {
    background: none;
    border: none;
    color: var(--rojo);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
  }

  /* DEUDAS */
  .deuda-card {
    background: var(--crema);
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 10px;
    border-left: 4px solid var(--rojo);
  }
  .deuda-card.pagada { border-left-color: var(--verde); opacity: 0.6; }
  .deuda-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
  .deuda-nombre { font-weight: 800; font-size: 0.95rem; }
  .deuda-original { font-size: 0.78rem; color: var(--gris); }
  .deuda-pendiente { font-size: 1.1rem; font-weight: 800; color: var(--rojo); }
  .deuda-card.pagada .deuda-pendiente { color: var(--verde); }
  .progress-bar { height: 6px; background: #e0e0e0; border-radius: 3px; margin: 8px 0; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--verde); border-radius: 3px; transition: width 0.5s; }
  .deuda-acciones { display: flex; gap: 8px; margin-top: 8px; }
  .deuda-pago-input { flex: 1; padding: 6px 10px; border: 2px solid var(--crema2); border-radius: 8px; font-family: 'Nunito', sans-serif; font-size: 0.85rem; }

  /* RESUMEN */
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .stat-box {
    background: var(--crema);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
  }
  .stat-box.verde { background: #e8f5ee; }
  .stat-box.rojo { background: #fdecea; }
  .stat-box.naranja { background: #fef0e4; }
  .stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; color: var(--gris); margin-bottom: 4px; }
  .stat-value { font-size: 1.4rem; font-weight: 800; color: var(--cafe); }
  .stat-value.verde { color: var(--verde); }
  .stat-value.rojo { color: var(--rojo); }
  .stat-value.naranja { color: var(--naranja); }

  .chart-container { position: relative; height: 240px; }

  /* VENTAS DETALLE */
  .ventas-detalle { font-size: 0.82rem; }
  .ventas-detalle tr:nth-child(even) td { background: var(--crema); }
  .ventas-detalle td, .ventas-detalle th { padding: 6px 10px; text-align: left; }
  .ventas-detalle th { font-weight: 700; color: var(--cafe-light); text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.5px; }
  table { width: 100%; border-collapse: collapse; }

  /* BADGE */
  .badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; }
  .badge-verde { background: #d4edda; color: #1a6b3a; }
  .badge-naranja { background: #fde8d5; color: #a0440e; }

  /* TOAST */
  .toast {
    position: fixed; bottom: 70px; left: 50%; transform: translateX(-50%);
    background: var(--cafe);
    color: white;
    padding: 10px 22px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.88rem;
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s;
    white-space: nowrap;
  }
  .toast.show { opacity: 1; }

  /* EMPTY STATE */
  .empty { text-align: center; padding: 30px; color: var(--gris); }
  .empty-icon { font-size: 2.5rem; margin-bottom: 8px; }

  .section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 800;
    color: var(--naranja);
    margin: 16px 0 8px;
    padding-left: 4px;
  }

  .total-venta {
    background: linear-gradient(135deg, var(--cafe), var(--cafe-light));
    color: white;
    border-radius: 12px;
    padding: 14px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
  }
  .total-venta-label { font-size: 0.85rem; font-weight: 700; opacity: 0.8; }
  .total-venta-monto { font-size: 1.4rem; font-weight: 900; }

  .cierre-btn {
    background: linear-gradient(135deg, var(--verde), #1a5e46);
    color: white;
    border: none;
    width: 100%;
    padding: 16px;
    border-radius: 14px;
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    cursor: pointer;
    margin-top: 8px;
    box-shadow: 0 4px 16px rgba(46,125,94,0.35);
    transition: transform 0.15s;
  }
  .cierre-btn:hover { transform: scale(1.01); }

  @media (max-width: 400px) {
    .stat-grid { grid-template-columns: 1fr 1fr; }
    .stat-value { font-size: 1.1rem; }
  }

  /* ===== MODO OSCURO OLED ===== */
  body.dark {
    --crema:  #000000;
    --crema2: #0d0d0d;
    --cafe:   #F0E0CC;
    --cafe-light: #C8A882;
    --gris:   #555555;
    --sombra: 0 4px 20px rgba(0,0,0,0.7);
    background: #000;
    color: #F0E0CC;
  }
  body.dark header { background: #000; border-bottom: 1px solid #1a1a1a; box-shadow: 0 2px 12px rgba(0,0,0,0.9); color: #F0E0CC; }
  body.dark .tabs { background: #050505; border-bottom: 1px solid #1a1a1a; }
  body.dark .tab { color: rgba(255,255,255,0.3); }
  body.dark .tab:hover { color: rgba(255,255,255,0.65); }
  body.dark .card { background: #0f0f0f; border: 1px solid #1c1c1c; box-shadow: none; }
  body.dark .plato-compact { background: #1a1a1a; }
  body.dark .tog-group { background: #080808; border-color: #252525; }
  body.dark .tog-btn { color: #555; }
  body.dark .plato-compact-sel { background: #080808; border-color: #252525; color: #777; }
  body.dark .producto-row { border-bottom-color: #1c1c1c; }
  body.dark .qty-minus { background: #1e1e1e; color: #bbb; }
  body.dark .form-control { background: #0f0f0f; border-color: #252525; color: #F0E0CC; }
  body.dark .form-control:focus { border-color: var(--naranja); }
  body.dark .item-lista { background: #1a1a1a; }
  body.dark .deuda-card { background: #1a1a1a; }
  body.dark .deuda-pago-input { background: #0f0f0f; border-color: #252525; color: #F0E0CC; }
  body.dark .stat-box { background: #1a1a1a; }
  body.dark .stat-box.verde  { background: #091510; }
  body.dark .stat-box.rojo   { background: #150909; }
  body.dark .stat-box.naranja{ background: #180e04; }
  body.dark .total-venta { background: linear-gradient(135deg,#0f0f0f,#1a1a1a); border: 1px solid #252525; }
  body.dark .marca-btn { background: #1a1a1a; color: #aaa; }
  body.dark .marca-btn.selected { background: #2e2e2e; color: white; }
  body.dark .dia-selector { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }
  body.dark .dia-selector option { background: #111; color: #F0E0CC; }
  body.dark .progress-bar { background: #222; }
  body.dark .ventas-detalle tr:nth-child(even) td { background: #1a1a1a; }
  body.dark .section-label { color: var(--naranja-light); }
  body.dark .empty { color: #444; }
  body.dark .badge-verde { background: #0d2014; color: #5fcf8a; }
  body.dark .badge-naranja { background: #1f1005; color: #f5913a; }
  body.dark .card-title { color: #C8A882; }

  /* Toggle button */
  .dark-toggle-wrap { display: flex; flex-direction: column; align-items: center; gap: 3px; margin-left: 12px; }
  .dark-toggle-label { font-size: 0.6rem; opacity: 0.6; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: white; }
  .dark-toggle {
    background: rgba(255,255,255,0.12);
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 50px;
    width: 46px; height: 26px;
    cursor: pointer;
    position: relative;
    transition: background 0.3s, border-color 0.3s;
    flex-shrink: 0;
  }
  .dark-toggle::after {
    content: '☀️';
    position: absolute;
    top: 2px; left: 2px;
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; line-height: 20px; text-align: center;
    transition: transform 0.3s;
  }
  body.dark .dark-toggle { background: #1a1a1a; border-color: var(--naranja); }
  body.dark .dark-toggle::after { content: '🌙'; transform: translateX(20px); }


  /* Iconos con mejor contraste en modo OLED */
  body.dark .tab-icon {
    filter: brightness(1.5) saturate(1.3);
    display: block;
  }
  body.dark .empty-icon {
    filter: brightness(1.4) saturate(1.2);
  }
  /* Sección labels y card titles tienen texto + emoji: solo subir brillo del emoji via text-shadow trick no aplica,
     pero podemos hacer el emoji más brillante indirectamente con saturate en el contenedor */
  body.dark .section-label,
  body.dark .card-title {
    filter: brightness(1.25) saturate(1.15);
  }
  body.dark .stat-label {
    filter: brightness(1.2);
  }
  body.dark .btn-eliminar {
    filter: brightness(1.3);
  }


  /* RESUMEN SUBTABS */
  .res-subtabs {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    background: white;
    border-radius: 12px;
    padding: 4px;
    box-shadow: var(--sombra);
  }
  body.dark .res-subtabs { background: #111; border: 1px solid #1e1e1e; }
  .res-subtab {
    flex: 1;
    text-align: center;
    padding: 9px 6px;
    border-radius: 9px;
    font-size: 0.78rem;
    font-weight: 800;
    cursor: pointer;
    color: var(--gris);
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }
  .res-subtab.active { background: var(--naranja); color: white; }
  body.dark .res-subtab:not(.active) { color: #555; }

  /* HISTORIAL SEMANA CARD */
  .hist-semana {
    background: white;
    border-radius: 14px;
    margin-bottom: 14px;
    overflow: hidden;
    box-shadow: var(--sombra);
  }
  body.dark .hist-semana { background: #0f0f0f; border: 1px solid #1c1c1c; }
  .hist-semana-header {
    padding: 14px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    background: linear-gradient(135deg, var(--cafe), var(--cafe-light));
    color: white;
  }
  .hist-semana-titulo { font-family: "Playfair Display", serif; font-size: 1rem; }
  .hist-semana-total { font-size: 1.2rem; font-weight: 900; color: var(--amarillo); }
  .hist-semana-body { padding: 14px 16px; display: none; }
  .hist-semana-body.open { display: block; }

  .hist-dia-label {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--naranja);
    margin: 12px 0 6px;
  }
  .hist-prod-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    padding: 4px 0;
    border-bottom: 1px dashed var(--crema2);
    color: var(--cafe);
  }
  body.dark .hist-prod-row { border-bottom-color: #1e1e1e; color: #C8A882; }
  .hist-prod-row:last-child { border-bottom: none; }
  .hist-stat-mini {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .hist-stat-mini-item {
    background: var(--crema);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 0.72rem;
    font-weight: 700;
  }
  body.dark .hist-stat-mini-item { background: #1a1a1a; color: #C8A882; }

  /* MES CARD */
  .mes-card {
    background: white;
    border-radius: 14px;
    margin-bottom: 14px;
    overflow: hidden;
    box-shadow: var(--sombra);
  }
  body.dark .mes-card { background: #0f0f0f; border: 1px solid #1c1c1c; }
  .mes-card-header {
    padding: 14px 16px;
    background: linear-gradient(135deg, #1a3a5c, #2a5a8c);
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
  }
  .mes-card-titulo { font-family: "Playfair Display", serif; font-size: 1rem; }
  .mes-card-total { font-size: 1.2rem; font-weight: 900; color: var(--amarillo); }
  .mes-card-body { padding: 14px; display: none; }
  .mes-card-body.open { display: block; }
  .mes-semana-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 10px;
    background: var(--crema);
    border-radius: 8px;
    margin-bottom: 6px;
    font-size: 0.83rem;
    font-weight: 700;
  }
  body.dark .mes-semana-item { background: #1a1a1a; color: #C8A882; }


  /* SETUP SCREEN */
  .setup-step {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-bottom: 12px;
    font-size: 0.82rem;
    color: #aaa;
    line-height: 1.5;
  }
  .setup-num {
    background: var(--naranja);
    color: white;
    border-radius: 50%;
    width: 22px; height: 22px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem;
    font-weight: 800;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .cloud-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #5fcf8a;
    margin-right: 5px;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { opacity:1; }
    50% { opacity:0.3; }
  }

</style>
<!-- Firebase SDK -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getDatabase, ref, onValue, set } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

  const firebaseConfig = {
    apiKey: "AIzaSyCrMzLYPpkunvfFH26mzSI51TmuXMcIA-k",
    authDomain: "sasoncostenolm.firebaseapp.com",
    databaseURL: "https://sasoncostenolm-default-rtdb.firebaseio.com",
    projectId: "sasoncostenolm",
    storageBucket: "sasoncostenolm.firebasestorage.app",
    messagingSenderId: "915624791749",
    appId: "1:915624791749:web:eb06034c598a7989cfeaac"
  };

  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);
  window._fbModules = { getDatabase, ref, onValue, set, db };
</script>
</head>
<body>


<!-- Barra de estado de conexión -->
<div id="syncBar" style="display:none;background:#0d1f17;border-bottom:1px solid #1a3a2a;padding:6px 16px;text-align:center;font-size:0.72rem;font-weight:700;color:#5fcf8a;letter-spacing:0.5px;">
  ☁️ SINCRONIZADO EN LA NUBE — LOS CAMBIOS SE COMPARTEN EN TIEMPO REAL
</div>

<header>
  <div style="display:flex;align-items:center;gap:8px;">
    <img src="data:image/png;base64," alt="Sazón Costeño" style="height:54px;width:auto;object-fit:contain;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.5));">
  </div>
  <div style="display:flex;align-items:center;gap:8px;">
    <div class="header-fecha">
      <select class="dia-selector" id="diaSelector" onchange="cambiarDia()">
        <option value="viernes">📅 Viernes</option>
        <option value="sabado" selected>📅 Sábado</option>
        <option value="domingo">📅 Domingo</option>
      </select>
      <div style="font-size:0.72rem;opacity:0.7;margin-top:4px;" id="fechaHoy"></div>
    </div>
    <div class="dark-toggle-wrap">
      <div class="dark-toggle" id="darkToggle" onclick="toggleDark()" title="Modo oscuro"></div>
      <span class="dark-toggle-label" id="darkLabel">Claro</span>
    </div>
  </div>
</header>

<div class="tabs">
  <div class="tab active" onclick="showTab('ventas')"><span class="tab-icon">🍽️</span>Ventas</div>
  <div class="tab" onclick="showTab('gastos')"><span class="tab-icon">💸</span>Gastos</div>
  <div class="tab" onclick="showTab('compras')"><span class="tab-icon">🛒</span>Compras</div>
  <div class="tab" onclick="showTab('resumen')"><span class="tab-icon">📊</span>Resumen</div>
  <div class="tab" onclick="showTab('deudas')"><span class="tab-icon">📋</span>Deudas</div>
  <div class="tab" onclick="showTab('historial')"><span class="tab-icon">📅</span>Historial</div>
</div>

<!-- ===== VENTAS ===== -->
<div class="content active" id="tab-ventas">

  <div class="section-label">🍛 Platos</div>
  <div class="card">
    <div id="platosContainer"></div>
  </div>

  <div class="section-label">🥤 Bebidas</div>
  <div class="card">
    <div id="bebidasContainer"></div>
  </div>

  <div class="section-label">🍲 Adicionales / Porciones</div>
  <div class="card">
    <div id="adicionalesContainer"></div>
  </div>

  <div class="total-venta">
    <div>
      <div class="total-venta-label">Total registrado hoy</div>
      <div style="font-size:0.75rem;opacity:0.6;" id="totalUnidades">0 productos vendidos</div>
    </div>
    <div class="total-venta-monto" id="totalVentaHoy">$0.00</div>
  </div>

  <button class="btn btn-primary btn-full" onclick="registrarVenta()">✅ Registrar venta del día</button>
  <p style="text-align:center;font-size:0.75rem;color:var(--gris);margin-top:8px;">Las ventas se acumulan al presionar este botón</p>

</div>

<!-- ===== GASTOS ===== -->
<div class="content" id="tab-gastos">
  <div class="card">
    <div class="card-title">💸 Agregar Gasto</div>
    <div class="form-group">
      <label>Descripción del gasto</label>
      <input class="form-control" id="gastoNombre" placeholder="Ej: Transporte, limpieza...">
    </div>
    <div class="form-group">
      <label>Monto ($)</label>
      <input class="form-control" type="number" id="gastoMonto" placeholder="0.00" step="0.01">
    </div>
    <button class="btn btn-primary btn-full" onclick="agregarGasto()">+ Agregar gasto</button>
  </div>

  <div class="card">
    <div class="card-title">📋 Gastos del día</div>
    <div id="listaGastos"><div class="empty"><div class="empty-icon">💸</div>No hay gastos registrados</div></div>
    <div id="totalGastosBox" style="display:none" class="total-venta" style="margin-top:12px;">
      <div class="total-venta-label">Total gastos</div>
      <div class="total-venta-monto" id="totalGastos">$0.00</div>
    </div>
  </div>
</div>

<!-- ===== COMPRAS ===== -->
<div class="content" id="tab-compras">
  <div class="card">
    <div class="card-title">🛒 Registrar Compra/Material</div>
    <div class="form-group">
      <label>Descripción</label>
      <input class="form-control" id="compraNombre" placeholder="Ej: Verduras, carne, yuca...">
    </div>
    <div class="form-group">
      <label>Cantidad / Detalle (opcional)</label>
      <input class="form-control" id="compraCantidad" placeholder="Ej: 5 kg, 2 atados...">
    </div>
    <div class="form-group">
      <label>Costo ($)</label>
      <input class="form-control" type="number" id="compraMonto" placeholder="0.00" step="0.01">
    </div>
    <button class="btn btn-primary btn-full" onclick="agregarCompra()">+ Registrar compra</button>
  </div>

  <div class="card">
    <div class="card-title">📦 Compras del día</div>
    <div id="listaCompras"><div class="empty"><div class="empty-icon">🛒</div>No hay compras registradas</div></div>
    <div id="totalComprasBox" style="display:none" class="total-venta">
      <div class="total-venta-label">Total invertido</div>
      <div class="total-venta-monto" id="totalCompras">$0.00</div>
    </div>
  </div>
</div>

<!-- ===== RESUMEN ===== -->
<div class="content" id="tab-resumen">

  <!-- Tabs día / semana dentro del resumen -->
  <div class="res-subtabs">
    <div class="res-subtab active" id="rst-dia" onclick="switchResTab('dia')">📆 Este Día</div>
    <div class="res-subtab" id="rst-semana" onclick="switchResTab('semana')">📅 Esta Semana</div>
  </div>

  <!-- Vista DÍA -->
  <div id="resView-dia">
    <div class="card">
      <div class="card-title">📊 Resumen del Día — <span id="resumenDia" style="color:var(--naranja)">Sábado</span></div>
      <div class="stat-grid">
        <div class="stat-box verde"><div class="stat-label">💰 Ventas</div><div class="stat-value verde" id="resVentas">$0.00</div></div>
        <div class="stat-box rojo"><div class="stat-label">💸 Gastos</div><div class="stat-value rojo" id="resGastos">$0.00</div></div>
        <div class="stat-box rojo"><div class="stat-label">🛒 Compras</div><div class="stat-value rojo" id="resCompras">$0.00</div></div>
        <div class="stat-box naranja"><div class="stat-label">📈 Ganancia</div><div class="stat-value naranja" id="resGanancia">$0.00</div></div>
      </div>
      <div class="chart-container"><canvas id="pieChart"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title">🍽️ Detalle por Producto</div>
      <div id="detalleVentas"><div class="empty"><div class="empty-icon">📊</div>Registra ventas para ver el detalle</div></div>
    </div>
    <button class="cierre-btn" onclick="cerrarSemana()">🔒 Cerrar Semana y Guardar</button>
  </div>

  <!-- Vista SEMANA -->
  <div id="resView-semana" style="display:none">
    <div class="card">
      <div class="card-title">📅 Totales de la Semana Actual</div>
      <div class="stat-grid">
        <div class="stat-box verde"><div class="stat-label">💰 Ventas</div><div class="stat-value verde" id="swVentas">$0.00</div></div>
        <div class="stat-box rojo"><div class="stat-label">💸 Gastos</div><div class="stat-value rojo" id="swGastos">$0.00</div></div>
        <div class="stat-box rojo"><div class="stat-label">🛒 Compras</div><div class="stat-value rojo" id="swCompras">$0.00</div></div>
        <div class="stat-box naranja"><div class="stat-label">📈 Ganancia</div><div class="stat-value naranja" id="swGanancia">$0.00</div></div>
      </div>
      <div class="chart-container"><canvas id="pieChartSemana"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title">🍽️ Desglose por Día y Producto</div>
      <div id="detalleSemana"></div>
    </div>
    <button class="cierre-btn" onclick="cerrarSemana()">🔒 Cerrar Semana y Guardar</button>
  </div>
</div>

<!-- ===== DEUDAS ===== -->
<div class="content" id="tab-deudas">
  <div class="card">
    <div class="card-title">➕ Registrar Nueva Deuda</div>
    <div class="form-group">
      <label>Nombre / A quién se le debe</label>
      <input class="form-control" id="deudaNombre" placeholder="Ej: Proveedor de carne, Juan...">
    </div>
    <div class="form-group">
      <label>Concepto</label>
      <input class="form-control" id="deudaConcepto" placeholder="Ej: Préstamo, mercadería...">
    </div>
    <div class="form-group">
      <label>Monto total de la deuda ($)</label>
      <input class="form-control" type="number" id="deudaMonto" placeholder="0.00" step="0.01">
    </div>
    <button class="btn btn-primary btn-full" onclick="agregarDeuda()">+ Registrar deuda</button>
  </div>

  <div class="card">
    <div class="card-title">📋 Deudas del Local</div>
    <div id="listaDeudas"><div class="empty"><div class="empty-icon">✅</div>¡No tienes deudas registradas!</div></div>
    <div id="resumenDeudas" style="margin-top:10px;display:none;" class="total-venta">
      <div class="total-venta-label">Total pendiente</div>
      <div class="total-venta-monto" id="totalDeudas">$0.00</div>
    </div>
  </div>
</div>


<!-- ===== HISTORIAL ===== -->
<div class="content" id="tab-historial">

  <!-- Sub-tabs semanas / mes -->
  <div class="res-subtabs">
    <div class="res-subtab active" id="hst-semanas" onclick="switchHistTab('semanas')">📅 Semanas</div>
    <div class="res-subtab" id="hst-mes" onclick="switchHistTab('mes')">🗓️ Por Mes</div>
  </div>

  <!-- Semanas -->
  <div id="histView-semanas">
    <div id="listaHistorialSemanas">
      <div class="empty"><div class="empty-icon">📅</div>Cierra semanas para ver el historial</div>
    </div>
  </div>

  <!-- Mes -->
  <div id="histView-mes" style="display:none">
    <div id="listaHistorialMes">
      <div class="empty"><div class="empty-icon">🗓️</div>Sin historial mensual aún</div>
    </div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>
// ============================================================
//  MODO OSCURO OLED
// ============================================================
function toggleDark() {
  const isDark = document.body.classList.toggle('dark');
  localStorage.setItem('scDark', isDark ? '1' : '0');
  document.getElementById('darkLabel').textContent = isDark ? 'OLED' : 'Claro';
}
function initDark() {
  const saved = localStorage.getItem('scDark');
  if (saved === '1') {
    document.body.classList.add('dark');
    document.getElementById('darkLabel').textContent = 'OLED';
  }
}

// ============================================================
//  DATOS Y ESTRUCTURA
// ============================================================
const DIAS = ['viernes','sabado','domingo'];

const MENU = {
  platos: [
    { id:'picadita_entera_servir', nombre:'Picadita entera – Para servir', precio:4.00, grupo:'picaditas' },
    { id:'picadita_entera_llevar', nombre:'Picadita entera – Para llevar', precio:4.25, grupo:'picaditas' },
    { id:'media_picada_servir',    nombre:'Media picada – Para servir',    precio:3.00, grupo:'picaditas' },
    { id:'media_picada_llevar',    nombre:'Media picada – Para llevar',    precio:3.25, grupo:'picaditas' },
    { id:'caldo_entero_servir',    nombre:'Caldo entero – Para servir',    precio:4.00, grupo:'caldos' },
    { id:'caldo_entero_llevar',    nombre:'Caldo entero – Para llevar',    precio:4.25, grupo:'caldos' },
    { id:'medio_caldo_servir',     nombre:'Medio caldo – Para servir',     precio:3.00, grupo:'caldos' },
    { id:'medio_caldo_llevar',     nombre:'Medio caldo – Para llevar',     precio:3.25, grupo:'caldos' },
  ],
  bebidas: [
    { id:'limonada_vaso',   nombre:'Limonada – Vaso personal', precio:0.50 },
    { id:'limonada_jarra',  nombre:'Limonada – Jarra',         precio:1.50 },
    { id:'cola_personal',   nombre:'Cola personal',            precio:0.75, marcas:['Inka','Coca Cola','Sprite','Fiora','Fanta'] },
    { id:'cola_litro',      nombre:'Cola litro',               precio:1.50, marcas:['Inka','Coca Cola','Sprite','Fiora','Fanta'] },
    { id:'agua_personal',   nombre:'Agua personal',            precio:0.50 },
  ],
  adicionales: [
    { id:'porcion_caldo',      nombre:'Porción de caldo',       precio:1.00 },
    { id:'porcion_menudencia', nombre:'Porción de menudencia',  precio:1.00 },
    { id:'porcion_pata',       nombre:'Porción de pata de chancho', precio:1.00 },
  ]
};

// Estado actual de cantidades en el formulario
let cantidades = {};
// Datos persistidos
let datos = {};
// Firebase refs
let _dataRef = null;

function cargarDatos() {
  try { return JSON.parse(localStorage.getItem('sazonCosteno') || '{}'); }
  catch(e) { return {}; }
}

function guardarDatos() {
  localStorage.setItem('sazonCosteno', JSON.stringify(datos));
  if (_dataRef) {
    const { set } = window._fbModules;
    set(_dataRef, datos).catch(e => console.warn('Firebase write error:', e));
  }
}

// Firebase auto-conectado al cargar

function refreshAllViews() {
  renderPlatos(); renderBebidas(); renderAdicionales();
  updateTotalVenta();
  actualizarResumen();
  renderGastos();
  renderCompras();
  renderDeudas();
}
function getDia() {
  return document.getElementById('diaSelector').value;
}
function getDatosDia(dia) {
  if (!datos[dia]) datos[dia] = { ventas:{}, gastos:[], compras:[] };
  return datos[dia];
}

// ============================================================
//  INIT
// ============================================================
window.onload = function() {
  initDark();
  document.getElementById('fechaHoy').textContent = new Date().toLocaleDateString('es-EC',{weekday:'long',day:'numeric',month:'long'});

  // Wait for Firebase module to load then connect
  setTimeout(autoConectarFirebase, 400);
};

function autoConectarFirebase() {
  try {
    const { db, ref, onValue } = window._fbModules;
    _dataRef = ref(db, 'sazonCosteno');

    // Show sync bar
    document.getElementById('syncBar').style.display = 'block';
    document.getElementById('syncBar').innerHTML =
      '<span class="cloud-dot"></span>CONECTANDO A LA NUBE...';

    // Real-time listener — syncs data across all devices instantly
    onValue(_dataRef, (snapshot) => {
      const val = snapshot.val();
      datos = val && typeof val === 'object' ? val : cargarDatos();
      localStorage.setItem('sazonCosteno', JSON.stringify(datos));
      document.getElementById('syncBar').innerHTML =
        '<span class="cloud-dot"></span>☁️ EN VIVO — TODO EL EQUIPO VE LO MISMO EN TIEMPO REAL';
      document.getElementById('syncBar').style.background = '#0d1f17';
      document.getElementById('syncBar').style.color = '#5fcf8a';
      refreshAllViews();
    }, (error) => {
      document.getElementById('syncBar').innerHTML = '⚠️ Sin conexión — guardando localmente';
      document.getElementById('syncBar').style.background = '#1f0d0d';
      document.getElementById('syncBar').style.color = '#e87070';
      datos = cargarDatos();
      refreshAllViews();
    });
  } catch(e) {
    console.warn('Firebase init error:', e);
    datos = cargarDatos();
    refreshAllViews();
  }
};



function cambiarDia() {
  cantidades = {};
  renderPlatos();
  renderBebidas();
  renderAdicionales();
  updateTotalVenta();
  renderGastos();
  renderCompras();
  actualizarResumen();
  renderDeudas();
}

// ============================================================
//  RENDER MENÚ
// ============================================================

// Estado de los toggles por grupo
let platoOpts = {
  picaditas: { tamano: 'entera', tipo: 'servir' },
  caldos:    { tamano: 'entero', tipo: 'servir' }
};

function getPlatoId(grupo) {
  const o = platoOpts[grupo];
  if(grupo === 'picaditas') {
    return o.tamano === 'entera'
      ? (o.tipo === 'servir' ? 'picadita_entera_servir' : 'picadita_entera_llevar')
      : (o.tipo === 'servir' ? 'media_picada_servir'    : 'media_picada_llevar');
  } else {
    return o.tamano === 'entero'
      ? (o.tipo === 'servir' ? 'caldo_entero_servir' : 'caldo_entero_llevar')
      : (o.tipo === 'servir' ? 'medio_caldo_servir'  : 'medio_caldo_llevar');
  }
}

function togglePlatoOpt(grupo, campo, valor) {
  platoOpts[grupo][campo] = valor;
  renderPlatos();
  updateTotalVenta();
}

function renderPlatos() {
  const c = document.getElementById('platosContainer');
  c.innerHTML = platoCard('picaditas','🍽️','Picaditas',['entera','media'],['Entera','Media'])
              + platoCard('caldos','🍲','Caldo de manguera',['entero','medio'],['Entero','Medio']);
}

function platoCard(grupo, icono, nombre, tamanos, tamanoLabels) {
  const o = platoOpts[grupo];
  const id = getPlatoId(grupo);
  const p = MENU.platos.find(x => x.id === id);
  const qty = cantidades[id] || 0;

  const btnTamano = tamanos.map((t, i) =>
    `<button class="tog-btn ${o.tamano===t?'tog-active':''}" onclick="togglePlatoOpt('${grupo}','tamano','${t}')">${tamanoLabels[i]}</button>`
  ).join('');

  const btnTipo =
    `<button class="tog-btn ${o.tipo==='servir'?'tog-active':''}" onclick="togglePlatoOpt('${grupo}','tipo','servir')">🍴 Servir</button>` +
    `<button class="tog-btn ${o.tipo==='llevar'?'tog-active':''}" onclick="togglePlatoOpt('${grupo}','tipo','llevar')">📦 Llevar</button>`;

  return `<div class="plato-compact">
    <div class="plato-compact-top">
      <div class="plato-compact-nombre">${icono} ${nombre}</div>
      <div class="plato-compact-precio">$${p.precio.toFixed(2)}</div>
    </div>
    <div class="plato-compact-opts">
      <div class="tog-group">${btnTamano}</div>
      <div class="tog-group">${btnTipo}</div>
    </div>
    <div class="plato-compact-bottom">
      <div class="plato-compact-sel" id="sel_${grupo}">
        ${o.tamano.charAt(0).toUpperCase()+o.tamano.slice(1)} · ${o.tipo.charAt(0).toUpperCase()+o.tipo.slice(1)}
      </div>
      <div class="qty-control">
        <button class="qty-btn qty-minus" onclick="cambiarQty('${id}',-1)">−</button>
        <span class="qty-num" id="qty_${id}">${qty}</span>
        <button class="qty-btn qty-plus" onclick="cambiarQty('${id}',1)">+</button>
      </div>
    </div>
  </div>`;
}

function renderBebidas() {
  const c = document.getElementById('bebidasContainer');
  c.innerHTML = MENU.bebidas.map(p => productoRow(p)).join('');
}

function renderAdicionales() {
  const c = document.getElementById('adicionalesContainer');
  c.innerHTML = MENU.adicionales.map(p => productoRow(p)).join('');
}

function productoRow(p) {
  const qty = cantidades[p.id] || 0;
  return `<div class="producto-row">
    <div class="prod-info">
      <div class="prod-nombre">${p.nombre}</div>
      <div class="prod-precio">$${p.precio.toFixed(2)}</div>
    </div>
    <div class="qty-control">
      <button class="qty-btn qty-minus" onclick="cambiarQty('${p.id}',-1)">−</button>
      <span class="qty-num" id="qty_${p.id}">${qty}</span>
      <button class="qty-btn qty-plus" onclick="cambiarQty('${p.id}',1)">+</button>
    </div>
  </div>`;
}

function cambiarQty(id, delta) {
  cantidades[id] = Math.max(0, (cantidades[id]||0) + delta);
  const el = document.getElementById('qty_'+id);
  if(el) el.textContent = cantidades[id];
  updateTotalVenta();
}

function getProductoById(id) {
  return [...MENU.platos,...MENU.bebidas,...MENU.adicionales].find(p=>p.id===id);
}

function updateTotalVenta() {
  let total = 0, unidades = 0;
  Object.entries(cantidades).forEach(([id,qty]) => {
    if(qty > 0) {
      const p = getProductoById(id);
      if(p) { total += p.precio * qty; unidades += qty; }
    }
  });
  document.getElementById('totalVentaHoy').textContent = '$'+total.toFixed(2);
  document.getElementById('totalUnidades').textContent = unidades + ' producto(s) a registrar';
}

function registrarVenta() {
  const dia = getDia();
  const dd = getDatosDia(dia);
  let hayAlgo = false;
  Object.entries(cantidades).forEach(([id,qty]) => {
    if(qty > 0) {
      hayAlgo = true;
      if(!dd.ventas[id]) dd.ventas[id] = 0;
      dd.ventas[id] += qty;
    }
  });
  if(!hayAlgo) { toast('⚠️ No hay productos seleccionados'); return; }
  guardarDatos();
  cantidades = {};
  renderPlatos(); renderBebidas(); renderAdicionales();
  updateTotalVenta();
  actualizarResumen();
  toast('✅ Venta registrada correctamente');
}

// ============================================================
//  GASTOS
// ============================================================
function agregarGasto() {
  const nombre = document.getElementById('gastoNombre').value.trim();
  const monto = parseFloat(document.getElementById('gastoMonto').value);
  if(!nombre || isNaN(monto) || monto<=0) { toast('⚠️ Completa todos los campos'); return; }
  const dia = getDia();
  const dd = getDatosDia(dia);
  dd.gastos.push({ id: Date.now(), nombre, monto });
  guardarDatos();
  document.getElementById('gastoNombre').value = '';
  document.getElementById('gastoMonto').value = '';
  renderGastos();
  actualizarResumen();
  toast('💸 Gasto registrado');
}

function eliminarGasto(id) {
  const dia = getDia();
  const dd = getDatosDia(dia);
  dd.gastos = dd.gastos.filter(g=>g.id!==id);
  guardarDatos();
  renderGastos();
  actualizarResumen();
}

function renderGastos() {
  const dia = getDia();
  const dd = getDatosDia(dia);
  const c = document.getElementById('listaGastos');
  if(!dd.gastos.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">💸</div>No hay gastos registrados</div>';
    document.getElementById('totalGastosBox').style.display='none';
    return;
  }
  let total = 0;
  c.innerHTML = dd.gastos.map(g => {
    total += g.monto;
    return `<div class="item-lista">
      <div><div class="item-lista-nombre">${g.nombre}</div></div>
      <div class="item-lista-monto">$${g.monto.toFixed(2)}</div>
      <button class="btn-eliminar" onclick="eliminarGasto(${g.id})">🗑</button>
    </div>`;
  }).join('');
  document.getElementById('totalGastosBox').style.display='flex';
  document.getElementById('totalGastos').textContent = '$'+total.toFixed(2);
}

// ============================================================
//  COMPRAS
// ============================================================
function agregarCompra() {
  const nombre = document.getElementById('compraNombre').value.trim();
  const cantidad = document.getElementById('compraCantidad').value.trim();
  const monto = parseFloat(document.getElementById('compraMonto').value);
  if(!nombre || isNaN(monto) || monto<=0) { toast('⚠️ Completa nombre y monto'); return; }
  const dia = getDia();
  const dd = getDatosDia(dia);
  dd.compras.push({ id: Date.now(), nombre, cantidad, monto });
  guardarDatos();
  document.getElementById('compraNombre').value = '';
  document.getElementById('compraCantidad').value = '';
  document.getElementById('compraMonto').value = '';
  renderCompras();
  actualizarResumen();
  toast('🛒 Compra registrada');
}

function eliminarCompra(id) {
  const dia = getDia();
  const dd = getDatosDia(dia);
  dd.compras = dd.compras.filter(c=>c.id!==id);
  guardarDatos();
  renderCompras();
  actualizarResumen();
}

function renderCompras() {
  const dia = getDia();
  const dd = getDatosDia(dia);
  const c = document.getElementById('listaCompras');
  if(!dd.compras.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">🛒</div>No hay compras registradas</div>';
    document.getElementById('totalComprasBox').style.display='none';
    return;
  }
  let total = 0;
  c.innerHTML = dd.compras.map(p => {
    total += p.monto;
    return `<div class="item-lista">
      <div>
        <div class="item-lista-nombre">${p.nombre}</div>
        ${p.cantidad ? `<div class="item-lista-nota">${p.cantidad}</div>` : ''}
      </div>
      <div class="item-lista-monto">$${p.monto.toFixed(2)}</div>
      <button class="btn-eliminar" onclick="eliminarCompra(${p.id})">🗑</button>
    </div>`;
  }).join('');
  document.getElementById('totalComprasBox').style.display='flex';
  document.getElementById('totalCompras').textContent = '$'+total.toFixed(2);
}

// ============================================================
//  RESUMEN Y GRÁFICO
// ============================================================
let pieChartInst = null;

function calcTotalesDia(dia) {
  const dd = getDatosDia(dia);
  let ventas = 0;
  Object.entries(dd.ventas).forEach(([id,qty]) => {
    const p = getProductoById(id);
    if(p) ventas += p.precio * qty;
  });
  const gastos = dd.gastos.reduce((s,g)=>s+g.monto,0);
  const compras = dd.compras.reduce((s,c)=>s+c.monto,0);
  return { ventas, gastos, compras, ganancia: ventas - gastos - compras };
}

function actualizarResumen() {
  const dia = getDia();
  const t = calcTotalesDia(dia);
  document.getElementById('resumenDia').textContent = dia.charAt(0).toUpperCase()+dia.slice(1);
  document.getElementById('resVentas').textContent = '$'+t.ventas.toFixed(2);
  document.getElementById('resGastos').textContent = '$'+t.gastos.toFixed(2);
  document.getElementById('resCompras').textContent = '$'+t.compras.toFixed(2);
  const gEl = document.getElementById('resGanancia');
  gEl.textContent = (t.ganancia>=0?'+':'') + '$'+t.ganancia.toFixed(2);
  gEl.style.color = t.ganancia >= 0 ? 'var(--verde)' : 'var(--rojo)';
  renderPieChart(t);
  renderDetalleVentas();
}

function renderPieChart(t) {
  const ctx = document.getElementById('pieChart').getContext('2d');
  const egreso = t.gastos + t.compras;
  const ganancia = Math.max(0, t.ganancia);
  if(pieChartInst) pieChartInst.destroy();
  pieChartInst = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['💰 Ganancias','💸 Gastos','🛒 Compras'],
      datasets: [{
        data: [ganancia || 0.01, t.gastos || 0, t.compras || 0],
        backgroundColor: ['#2E7D5E','#C0392B','#E8651A'],
        borderWidth: 3,
        borderColor: '#fff',
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position:'bottom', labels:{ font:{family:'Nunito',weight:'700'}, padding:16, color:'#6B3A1F' } },
        tooltip: {
          callbacks: {
            label: ctx => ' $'+ctx.parsed.toFixed(2)
          }
        }
      },
      cutout:'60%',
    }
  });
}

function renderDetalleVentas() {
  const dia = getDia();
  const dd = getDatosDia(dia);
  const c = document.getElementById('detalleVentas');
  const entries = Object.entries(dd.ventas).filter(([,q])=>q>0);
  if(!entries.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">📊</div>Registra ventas para ver el detalle</div>';
    return;
  }
  let rows = '';
  let total = 0;
  entries.forEach(([id,qty]) => {
    const p = getProductoById(id);
    if(!p) return;
    const sub = p.precio * qty;
    total += sub;
    rows += `<tr>
      <td>${p.nombre}</td>
      <td style="text-align:center;font-weight:700">${qty}</td>
      <td>$${p.precio.toFixed(2)}</td>
      <td style="font-weight:800;color:var(--verde)">$${sub.toFixed(2)}</td>
    </tr>`;
  });
  c.innerHTML = `<table class="ventas-detalle">
    <tr><th>Producto</th><th>Cant.</th><th>P.Unit</th><th>Subtotal</th></tr>
    ${rows}
    <tr style="border-top:2px solid var(--crema2)">
      <td colspan="3" style="font-weight:800">TOTAL</td>
      <td style="font-weight:900;color:var(--verde)">$${total.toFixed(2)}</td>
    </tr>
  </table>`;
}

function cerrarSemana() {
  if(!datos.viernes && !datos.sabado && !datos.domingo) { toast('⚠️ No hay datos que guardar'); return; }

  // Sumar todos los días disponibles
  const diasSemana = ['viernes','sabado','domingo'];
  let ventasSuma = {}, gastosSuma = [], comprasSuma = [];
  let totalVentas = 0, totalGastos = 0, totalCompras = 0;

  diasSemana.forEach(d => {
    const dd = datos[d];
    if(!dd) return;
    Object.entries(dd.ventas||{}).forEach(([id,q]) => {
      ventasSuma[id] = (ventasSuma[id]||0) + q;
    });
    (dd.gastos||[]).forEach(g => gastosSuma.push({...g, dia: d}));
    (dd.compras||[]).forEach(c => comprasSuma.push({...c, dia: d}));
  });

  diasSemana.forEach(d => {
    const t = calcTotalesDia(d);
    totalVentas  += t.ventas;
    totalGastos  += t.gastos;
    totalCompras += t.compras;
  });

  const ganancia = totalVentas - totalGastos - totalCompras;
  const ahora = new Date();
  const fechaStr = ahora.toLocaleDateString('es-EC',{day:'numeric',month:'long',year:'numeric'});
  const mesKey = ahora.getFullYear()+'-'+(ahora.getMonth()+1).toString().padStart(2,'0');

  // Snapshot completo por día para el desglose
  const snapshot = {};
  diasSemana.forEach(d => {
    if(datos[d]) snapshot[d] = JSON.parse(JSON.stringify(datos[d]));
  });

  if(!datos.semanas) datos.semanas = [];
  datos.semanas.unshift({
    id: Date.now(),
    fecha: fechaStr,
    mesKey,
    ventas: totalVentas,
    gastos: totalGastos,
    compras: totalCompras,
    ganancia,
    ventasSuma,
    snapshot
  });

  // Limpiar datos del día después de cerrar
  ['viernes','sabado','domingo'].forEach(d => {
    datos[d] = { ventas:{}, gastos:[], compras:[] };
  });

  guardarDatos();
  actualizarResumen();
  toast('✅ Semana cerrada y guardada');
}

// ============================================================
//  DEUDAS
// ============================================================
function agregarDeuda() {
  const nombre = document.getElementById('deudaNombre').value.trim();
  const concepto = document.getElementById('deudaConcepto').value.trim();
  const monto = parseFloat(document.getElementById('deudaMonto').value);
  if(!nombre || isNaN(monto) || monto<=0) { toast('⚠️ Completa nombre y monto'); return; }
  if(!datos.deudas) datos.deudas = [];
  datos.deudas.push({ id: Date.now(), nombre, concepto, montoOriginal: monto, montoPendiente: monto });
  guardarDatos();
  document.getElementById('deudaNombre').value = '';
  document.getElementById('deudaConcepto').value = '';
  document.getElementById('deudaMonto').value = '';
  renderDeudas();
  toast('📋 Deuda registrada');
}

function pagarDeuda(id) {
  const input = document.getElementById('pago_'+id);
  const pago = parseFloat(input.value);
  if(isNaN(pago) || pago<=0) { toast('⚠️ Ingresa un monto válido'); return; }
  const d = datos.deudas.find(x=>x.id===id);
  if(!d) return;
  d.montoPendiente = Math.max(0, d.montoPendiente - pago);
  guardarDatos();
  renderDeudas();
  toast('✅ Pago registrado: $'+pago.toFixed(2));
}

function eliminarDeuda(id) {
  if(!confirm('¿Eliminar esta deuda?')) return;
  datos.deudas = (datos.deudas||[]).filter(d=>d.id!==id);
  guardarDatos();
  renderDeudas();
}

function renderDeudas() {
  if(!datos.deudas) datos.deudas = [];
  const c = document.getElementById('listaDeudas');
  if(!datos.deudas.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">✅</div>¡No hay deudas registradas!</div>';
    document.getElementById('resumenDeudas').style.display='none';
    return;
  }
  let totalPend = 0;
  c.innerHTML = datos.deudas.map(d => {
    const pagado = d.montoOriginal - d.montoPendiente;
    const pct = (pagado / d.montoOriginal * 100).toFixed(0);
    const pagada = d.montoPendiente <= 0;
    totalPend += d.montoPendiente;
    return `<div class="deuda-card ${pagada?'pagada':''}">
      <div class="deuda-header">
        <div>
          <div class="deuda-nombre">${d.nombre}</div>
          ${d.concepto ? `<div class="deuda-original">${d.concepto}</div>` : ''}
          <div class="deuda-original">Total original: $${d.montoOriginal.toFixed(2)} · Pagado: $${pagado.toFixed(2)}</div>
        </div>
        <div>
          <div class="deuda-pendiente">${pagada?'✅ PAGADA':'$'+d.montoPendiente.toFixed(2)}</div>
          ${!pagada?`<div style="font-size:0.72rem;color:var(--gris);text-align:right">pendiente</div>`:''}
        </div>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
      <div style="font-size:0.72rem;color:var(--gris);margin-bottom:6px">${pct}% pagado</div>
      ${!pagada ? `<div class="deuda-acciones">
        <input class="deuda-pago-input" type="number" id="pago_${d.id}" placeholder="Monto a pagar..." step="0.01">
        <button class="btn btn-success btn-sm" onclick="pagarDeuda(${d.id})">💵 Pagar</button>
        <button class="btn btn-danger btn-sm" onclick="eliminarDeuda(${d.id})">🗑</button>
      </div>` : `<button class="btn btn-outline btn-sm" onclick="eliminarDeuda(${d.id})" style="width:100%">Eliminar</button>`}
    </div>`;
  }).join('');
  document.getElementById('resumenDeudas').style.display='flex';
  document.getElementById('totalDeudas').textContent = '$'+totalPend.toFixed(2);
}

// ============================================================
//  TABS
// ============================================================
function showTab(name) {
  document.querySelectorAll('.content').forEach(c=>c.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  event.currentTarget.classList.add('active');
  if(name==='resumen') actualizarResumen();
  if(name==='gastos') renderGastos();
  if(name==='compras') renderCompras();
  if(name==='deudas') renderDeudas();
  if(name==='historial') renderHistorial();
}

// ============================================================
//  RESUMEN SUB-TABS
// ============================================================
let resTabActual = 'dia';
function switchResTab(tab) {
  resTabActual = tab;
  document.getElementById('rst-dia').classList.toggle('active', tab==='dia');
  document.getElementById('rst-semana').classList.toggle('active', tab==='semana');
  document.getElementById('resView-dia').style.display = tab==='dia' ? '' : 'none';
  document.getElementById('resView-semana').style.display = tab==='semana' ? '' : 'none';
  if(tab==='semana') renderResumenSemana();
}

function renderResumenSemana() {
  const dias = ['viernes','sabado','domingo'];
  let totalV=0,totalG=0,totalC=0;
  dias.forEach(d => {
    const t = calcTotalesDia(d);
    totalV += t.ventas; totalG += t.gastos; totalC += t.compras;
  });
  const gan = totalV - totalG - totalC;

  document.getElementById('swVentas').textContent  = '$'+totalV.toFixed(2);
  document.getElementById('swGastos').textContent  = '$'+totalG.toFixed(2);
  document.getElementById('swCompras').textContent = '$'+totalC.toFixed(2);
  const ge = document.getElementById('swGanancia');
  ge.textContent = (gan>=0?'+':'')+'$'+gan.toFixed(2);
  ge.style.color = gan>=0 ? 'var(--verde)' : 'var(--rojo)';

  // Gráfico semana
  const ctx2 = document.getElementById('pieChartSemana').getContext('2d');
  if(window._pieChartSemana) window._pieChartSemana.destroy();
  window._pieChartSemana = new Chart(ctx2,{
    type:'doughnut',
    data:{
      labels:['💰 Ganancias','💸 Gastos','🛒 Compras'],
      datasets:[{ data:[Math.max(0,gan),totalG,totalC], backgroundColor:['#2E7D5E','#C0392B','#E8651A'], borderWidth:3, borderColor:'#fff' }]
    },
    options:{ responsive:true, maintainAspectRatio:false, cutout:'60%',
      plugins:{ legend:{position:'bottom',labels:{font:{family:'Nunito',weight:'700'},padding:16,color:'#6B3A1F'}},
        tooltip:{callbacks:{label:ctx=>' $'+ctx.parsed.toFixed(2)}} }
    }
  });

  // Desglose por día y producto
  const c = document.getElementById('detalleSemana');
  let html = '';
  dias.forEach(dia => {
    const dd = getDatosDia(dia);
    const entries = Object.entries(dd.ventas).filter(([,q])=>q>0);
    if(!entries.length) return;
    html += `<div class="hist-dia-label">${dia.charAt(0).toUpperCase()+dia.slice(1)}</div>`;
    entries.forEach(([id,qty]) => {
      const p = getProductoById(id);
      if(!p) return;
      html += `<div class="hist-prod-row"><span>${p.nombre}</span><span><b>${qty}</b> × $${p.precio.toFixed(2)} = <b style="color:var(--verde)">$${(p.precio*qty).toFixed(2)}</b></span></div>`;
    });
  });
  if(!html) html = '<div class="empty"><div class="empty-icon">🍽️</div>No hay ventas esta semana</div>';
  c.innerHTML = html;
}

// ============================================================
//  HISTORIAL
// ============================================================
let histTabActual = 'semanas';
function switchHistTab(tab) {
  histTabActual = tab;
  document.getElementById('hst-semanas').classList.toggle('active', tab==='semanas');
  document.getElementById('hst-mes').classList.toggle('active', tab==='mes');
  document.getElementById('histView-semanas').style.display = tab==='semanas' ? '' : 'none';
  document.getElementById('histView-mes').style.display = tab==='mes' ? '' : 'none';
  if(tab==='mes') renderHistorialMes();
  else renderHistorialSemanas();
}

function renderHistorial() {
  renderHistorialSemanas();
}

function toggleHistSemana(id) {
  const el = document.getElementById('hbody_'+id);
  if(el) el.classList.toggle('open');
}
function toggleMesCard(key) {
  const el = document.getElementById('mesbody_'+key);
  if(el) el.classList.toggle('open');
}

function renderHistorialSemanas() {
  const semanas = datos.semanas || [];
  const c = document.getElementById('listaHistorialSemanas');
  if(!semanas.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">📅</div>Cierra semanas para ver el historial</div>';
    return;
  }
  c.innerHTML = semanas.map((s,i) => {
    // Desglose por día
    let desglose = '';
    const dias = ['viernes','sabado','domingo'];
    dias.forEach(dia => {
      const snap = s.snapshot && s.snapshot[dia];
      if(!snap) return;
      const entries = Object.entries(snap.ventas||{}).filter(([,q])=>q>0);
      if(!entries.length) return;
      desglose += `<div class="hist-dia-label">${dia.charAt(0).toUpperCase()+dia.slice(1)}</div>`;
      entries.forEach(([id,qty]) => {
        const p = getProductoById(id);
        if(!p) return;
        desglose += `<div class="hist-prod-row"><span>${p.nombre}</span><span><b>${qty}</b> × $${p.precio.toFixed(2)} = <b style="color:var(--verde)">$${(p.precio*qty).toFixed(2)}</b></span></div>`;
      });
      const tg = (snap.gastos||[]).reduce((a,g)=>a+g.monto,0);
      const tc = (snap.compras||[]).reduce((a,c)=>a+c.monto,0);
      desglose += `<div class="hist-stat-mini"><span class="hist-stat-mini-item">💸 Gastos: $${tg.toFixed(2)}</span><span class="hist-stat-mini-item">🛒 Compras: $${tc.toFixed(2)}</span></div>`;
    });

    return `<div class="hist-semana">
      <div class="hist-semana-header" onclick="toggleHistSemana(${s.id})">
        <div>
          <div class="hist-semana-titulo">📅 Semana ${semanas.length - i}</div>
          <div style="font-size:0.72rem;opacity:0.7;margin-top:2px">${s.fecha}</div>
        </div>
        <div style="text-align:right">
          <div class="hist-semana-total">$${s.ventas.toFixed(2)}</div>
          <div style="font-size:0.72rem;opacity:0.7">ventas · gan: ${s.ganancia>=0?'+':''}$${s.ganancia.toFixed(2)}</div>
        </div>
      </div>
      <div class="hist-semana-body" id="hbody_${s.id}">
        <div class="stat-grid" style="margin-bottom:12px">
          <div class="hist-stat-mini-item">💰 Ventas: $${s.ventas.toFixed(2)}</div>
          <div class="hist-stat-mini-item">💸 Gastos: $${s.gastos.toFixed(2)}</div>
          <div class="hist-stat-mini-item">🛒 Compras: $${s.compras.toFixed(2)}</div>
          <div class="hist-stat-mini-item" style="color:${s.ganancia>=0?'var(--verde)':'var(--rojo)'}">📈 Ganancia: ${s.ganancia>=0?'+':''}$${s.ganancia.toFixed(2)}</div>
        </div>
        ${desglose || '<div class="empty" style="padding:10px">Sin desglose disponible</div>'}
      </div>
    </div>`;
  }).join('');
}

function renderHistorialMes() {
  const semanas = datos.semanas || [];
  if(!semanas.length) {
    document.getElementById('listaHistorialMes').innerHTML = '<div class="empty"><div class="empty-icon">🗓️</div>Sin historial mensual aún</div>';
    return;
  }

  // Agrupar por mes
  const meses = {};
  semanas.forEach(s => {
    if(!meses[s.mesKey]) meses[s.mesKey] = { semanas:[], ventas:0, gastos:0, compras:0, ganancia:0 };
    meses[s.mesKey].semanas.push(s);
    meses[s.mesKey].ventas   += s.ventas;
    meses[s.mesKey].gastos   += s.gastos;
    meses[s.mesKey].compras  += s.compras;
    meses[s.mesKey].ganancia += s.ganancia;
  });

  const MESES_NOMBRE = ['','Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const keys = Object.keys(meses).sort().reverse();

  document.getElementById('listaHistorialMes').innerHTML = keys.map(key => {
    const m = meses[key];
    const [anio, mes] = key.split('-');
    const nombreMes = MESES_NOMBRE[parseInt(mes)] + ' ' + anio;
    const semanasHtml = m.semanas.map((s,i) =>
      `<div class="mes-semana-item">
        <span>📅 ${s.fecha}</span>
        <span style="color:var(--verde)">$${s.ventas.toFixed(2)}</span>
       </div>`
    ).join('');
    return `<div class="mes-card">
      <div class="mes-card-header" onclick="toggleMesCard('${key}')">
        <div>
          <div class="mes-card-titulo">🗓️ ${nombreMes}</div>
          <div style="font-size:0.72rem;opacity:0.7">${m.semanas.length} semana(s)</div>
        </div>
        <div style="text-align:right">
          <div class="mes-card-total">$${m.ventas.toFixed(2)}</div>
          <div style="font-size:0.72rem;opacity:0.7">gan: ${m.ganancia>=0?'+':''}$${m.ganancia.toFixed(2)}</div>
        </div>
      </div>
      <div class="mes-card-body" id="mesbody_${key}">
        <div class="stat-grid" style="margin-bottom:12px">
          <div class="hist-stat-mini-item">💰 Ventas: $${m.ventas.toFixed(2)}</div>
          <div class="hist-stat-mini-item">💸 Gastos: $${m.gastos.toFixed(2)}</div>
          <div class="hist-stat-mini-item">🛒 Compras: $${m.compras.toFixed(2)}</div>
          <div class="hist-stat-mini-item" style="color:${m.ganancia>=0?'var(--verde)':'var(--rojo)'}">📈 Ganancia: ${m.ganancia>=0?'+':''}$${m.ganancia.toFixed(2)}</div>
        </div>
        ${semanasHtml}
      </div>
    </div>`;
  }).join('');
}

// ============================================================
//  TOAST
// ============================================================
let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>el.classList.remove('show'), 2500);
}
</script>
</body>
</html>
